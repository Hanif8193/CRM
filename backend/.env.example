# ── Database (Railway provides this automatically as $DATABASE_URL) ────────────
DATABASE_URL=postgresql://user:password@localhost:5432/crm_db

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Gmail OAuth2 ──────────────────────────────────────────────────────────────
GMAIL_CLIENT_ID=your_gmail_client_id
GMAIL_CLIENT_SECRET=your_gmail_client_secret

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
WHATSAPP_API_TOKEN=your_whatsapp_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_custom_verify_token
WHATSAPP_APP_SECRET=your_meta_app_secret

# ── WhatsApp (Twilio Sandbox) — get from console.twilio.com ──────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token

# ── CORS — set to your Railway frontend URL ───────────────────────────────────
# Example: ALLOWED_ORIGINS=https://crm-frontend.up.railway.app
ALLOWED_ORIGINS=http://localhost:3000

# ── Kafka (add Kafka plugin in Railway, or use Upstash Kafka) ─────────────────
# Railway Kafka plugin sets KAFKA_BOOTSTRAP_SERVERS automatically
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

# ── App ───────────────────────────────────────────────────────────────────────
ENV=production
LOG_LEVEL=INFO

# ── Sentry (optional) ─────────────────────────────────────────────────────────
SENTRY_DSN=
