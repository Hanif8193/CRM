# ════════════════════════════════════════════════════════════════════════════════
# CRM AI Agent — Environment Variables
# تمام ضروری settings یہاں لکھی ہیں
#
# استعمال کا طریقہ / How to use:
#   Windows: copy .env.example .env
#   Linux:   cp .env.example .env
# پھر .env کھولیں اور اصل values بھریں۔ .env کو git میں commit نہ کریں!
# ════════════════════════════════════════════════════════════════════════════════


# ── ایپ کی بنیادی settings ───────────────────────────────────────────────────
# Basic application settings

# ماحول: development (local) یا production (server)
ENV=development

# Log کی سطح: DEBUG (سب دکھائے) → INFO → WARNING → ERROR (صرف errors)
LOG_LEVEL=INFO


# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# ڈیٹا بیس کنکشن — format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
# Docker Compose میں HOST = postgres (service name)
# Local dev میں HOST = localhost

DATABASE_URL=postgresql://postgres:postgres@localhost:5432/crm_db


# ── Anthropic / Claude AI ─────────────────────────────────────────────────────
# Claude AI کی API key — console.anthropic.com سے لیں
# Claude API key from console.anthropic.com

ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── Gmail OAuth2 — یہ سب سے اہم ہے ──────────────────────────────────────────
# Gmail OAuth2 credentials — MOST IMPORTANT
#
# کیسے بنائیں / How to get:
#   1. console.cloud.google.com کھولیں
#   2. APIs & Services → Credentials → Create Credentials
#   3. OAuth 2.0 Client ID → Desktop application → Create
#   4. JSON ڈاؤنلوڈ کریں → backend/ فولڈر میں رکھیں
#   5. نیچے path سیٹ کریں

# Gmail credentials JSON فائل کا نام (Google Console سے ڈاؤنلوڈ کریں)
# Name of the credentials JSON file downloaded from Google Console
GMAIL_CLIENT_PATH=gmail_credentials.json

# OAuth token فائل — پہلی بار OAuth کے بعد خودبخود بنتی ہے
# OAuth token file — auto-created after first OAuth flow
GMAIL_TOKEN_PATH=gmail_token.json


# ── CORS — کون سے frontend کو اجازت ہے ──────────────────────────────────────
# Which frontend origins are allowed to call this API
#
# Local development:
#   ALLOWED_ORIGINS=http://localhost:3000
#
# Production (comma-separated, کوئی space نہیں):
#   ALLOWED_ORIGINS=https://mycrm.com,https://app.mycrm.com
#
# کبھی * استعمال نہ کریں production میں!
# NEVER use * in production!

ALLOWED_ORIGINS=http://localhost:3000


# ── Rate Limiting — ایک IP سے زیادہ requests روکنا ──────────────────────────
# Prevent spam: max requests per IP per time window

# کتنی requests مانی جائیں (per window)
# Maximum requests allowed per IP per window
RATE_LIMIT_REQUESTS=5

# وقت کی ونڈو (سیکنڈوں میں) — 60 = ایک منٹ
# Time window in seconds — 60 = one minute
RATE_LIMIT_WINDOW=60


# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
# Meta Developer Console → Your App → WhatsApp → API Setup سے لیں
# Get from Meta Developer Console → App → WhatsApp → API Setup

# WhatsApp Business API token
WHATSAPP_API_TOKEN=

# WhatsApp phone number ID (not the actual number)
WHATSAPP_PHONE_NUMBER_ID=


# ── Kafka (Message Queue) ─────────────────────────────────────────────────────
# Kafka broker address
#
# Local (bare metal): localhost:9092
# Docker Compose:     kafka:29092  (docker-compose خودبخود override کرتا ہے)

KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Consumer group ID — ایک group کے workers مل کر messages تقسیم کریں گے
# Consumer group ID for worker coordination
KAFKA_CONSUMER_GROUP=crm-agent-workers


# ── Sentry — Error Tracking (اختیاری / Optional) ─────────────────────────────
# Production میں errors کو track کرنے کے لیے — sentry.io سے DSN لیں
# Track production errors — get DSN from sentry.io
# خالی چھوڑیں اگر نہیں چاہیے / Leave empty to disable

SENTRY_DSN=

# کتنے % transactions trace کریں (0.1 = 10%)
# What % of transactions to trace (0.1 = 10%)
SENTRY_TRACES_SAMPLE_RATE=0.1
